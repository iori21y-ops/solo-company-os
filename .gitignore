# 민감 정보 차단
.env
.env.*
*.key
*.pem
*_secret*
*_private*
credentials*

# 시스템 파일
.DS_Store
*.swp
*~

# 백업 파일
*.bak
*.backup
*.work-bak

# 로컬 전용 (향후 사업 디테일 박을 자리)
agents-private/
handoff/projects/*/private/

# 핸드오프 — 민감 파일만 개별 차단 (handoff-latest.md는 공개)
# 주의: 디렉토리 전체 차단 시 ! 예외가 git에서 작동하지 않아 파일별 지정
handoff/projects/**/DECISIONS.md
handoff/projects/**/current-state.md
handoff/projects/**/notes-private.md

# 핸드오프 시스템 — 자동 백업 파일 제외
*.bak2
*.bak3
*.prev

# Obsidian (agents vault용) — 사용자별 임시 파일 제외
agents/.obsidian/workspace.json
agents/.obsidian/workspace-mobile.json
agents/.obsidian/graph.json
agents/.obsidian/hotkeys.json
agents/.obsidian/appearance.json
agents/.obsidian/cache/
agents/.obsidian/plugins/*/data.json

# macOS
.DS_Store
*.bak.*

# ── 정리 1단계 추가 (2026-06-22): 런타임 로그·에이전트 산출물·백업 잔재 ──
# 로그 (런타임 산출물 — 버전관리 제외)
*.log
logs/*.log

# 에이전트 산출물 (approved/pending/rejected 등 대량 생성물)
agents/*/outputs/

# 콘텐츠 팩트블록 (대량 자동 생성)
agents/content/assets/cadam/fact-blocks/

# 백업 잔재 (*.bak·*.bak2는 위에서 이미 차단됨, *.bak-fix만 보강)
*.bak-fix
